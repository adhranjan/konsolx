{
  "name": "konsolx",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop terminal workspace manager for developers",
  "author": {
    "name": "Ranjan",
    "email": "adh.ranjan@gmail.com"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --watch & tsx watch server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "vite build && npm run build:server",
    "electron:dev": "npm run build && npm run build:electron && electron build-electron/main.js",
    "electron:build": "npm run build && npm run build:electron && electron-builder --linux --publish never"
  },
  "main": "build-electron/main.js",
  "build": {
    "appId": "com.konsolx.app",
    "productName": "Konsolx",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "build-electron/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build-assets",
      "category": "Development",
      "syncDesktopName": true
    },
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      }
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "^6.2.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
