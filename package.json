{
  "name": "konsolx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.ts",
  "scripts": {
    "dev": "tsx server.ts",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "vite build && npm run build:server"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.konsolx.app",
    "productName": "Konsolx",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.ts",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
